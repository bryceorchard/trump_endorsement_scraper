# Copy to .env and fill in values.
# The scripts/ helpers load this file (set -a; . .env; set +a). JSON values are
# single-quoted so they survive that sourcing intact — keep the quotes.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# scripts/setup.sh sets this for you (role trump_tracker_user + the password you choose).
DATABASE_URL=postgresql://trump_tracker_user:yourpassword@localhost/trump_tracker

# ── Truth Social ─────────────────────────────────────────────────────────────
# Trump's Mastodon-compatible account ID (default is correct as of mid-2025)
TRUTH_SOCIAL_ACCOUNT_ID=107780257626128497

# ── X / Twitter ──────────────────────────────────────────────────────────────
# At least one real Twitter account is required for twscrape
# Format: JSON array of account objects
# Quote the value (single quotes) so it survives shell sourcing of .env intact.
TWITTER_ACCOUNTS_JSON='[{"username":"your_twitter_user","password":"your_pass","email":"your@email.com","email_password":"email_pass"}]'
TWITTER_TARGET_USER=realDonaldTrump
# If password login fails with X's "Could not log you in now" (code 399) — X's
# anti-automation, not a config error — use browser cookies instead: log in to
# x.com in a browser, copy the auth_token and ct0 cookies, and add a "cookies"
# field to the account object (then remove src/accounts.db and re-run
# scripts/setup_twitter.sh):
#   TWITTER_ACCOUNTS_JSON='[{"username":"u","password":"p","email":"e","email_password":"ep","cookies":"auth_token=XXXX; ct0=YYYY"}]'

# ── Scheduling intervals (seconds) ───────────────────────────────────────────
INTERVAL_TRUTH_SOCIAL=300
INTERVAL_TWITTER=600
INTERVAL_WHITEHOUSE=900
INTERVAL_RSS=600

# ── RSS feeds (JSON array) ───────────────────────────────────────────────────
# Uncomment and modify to override defaults
# RSS_FEEDS_JSON='["https://feeds.reuters.com/reuters/politicsNews","https://rss.politico.com/politics-news.xml"]'

# ── RSS keyword filter ────────────────────────────────────────────────────────
RSS_FILTER_KEYWORDS='["trump","donald"]'

# ── Endorsement detection (Ollama) ───────────────────────────────────────────
# Set to false to run collectors without Ollama (items queue up unprocessed).
# DETECTION_ENABLED=true
# OLLAMA_MODEL=qwen3:8b
# Seconds per inference; first call after idle also pays model-load time.
# OLLAMA_TIMEOUT=180
